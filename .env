# MT5 Trading Bot Configuration
# IMPORTANT: Change all default values below before deploying!

# Basic Authentication (Web UI Login)
# ⚠️ CHANGE THESE IMMEDIATELY!
BASIC_USER=admin
BASIC_PASS=admin123

# Security
# Generate secure keys using: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-this-secret-key-to-something-secure
WEBHOOK_TOKEN=change-this-webhook-token
EXTERNAL_BASE_URL=http://localhost:5000

# Server
PORT=5000
DEBUG=False

# MT5 Configuration
MT5_MAIN_PATH=C:\Program Files\MetaTrader 5\terminal64.exe
MT5_INSTANCES_DIR=mt5_instances

DELETE_INSTANCE_FILES=False

# Email Notifications (Simplified Setup)
# Just need 3 variables: enable, sender email+password, recipients
EMAIL_ENABLED=True
SENDER_EMAIL=your.email@gmail.com
SENDER_PASSWORD=your_app_password_here
RECIPIENTS=alert1@gmail.com,alert2@gmail.com

# Symbol Mapping
SYMBOL_FETCH_ENABLED=False
FUZZY_MATCH_THRESHOLD=0.6

# Rate Limiting
RATE_LIMIT_WEBHOOK=10 per minute
RATE_LIMIT_API=100 per hour
